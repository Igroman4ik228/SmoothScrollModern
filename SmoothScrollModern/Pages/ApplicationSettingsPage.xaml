<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="SmoothScrollModern.Pages.ApplicationSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:settingsWidgets="using:SmoothScrollModern.Widgets.Settings">

    <ScrollViewer
        HorizontalScrollBarVisibility="Disabled"
        HorizontalScrollMode="Disabled"
        VerticalScrollBarVisibility="Auto">
        <StackPanel
            Margin="32,16,32,32"
            HorizontalAlignment="Stretch"
            Spacing="24">
            <settingsWidgets:SmoothScrollToggleBlock />
            <settingsWidgets:StartupWindowSettingsBlock />
            <settingsWidgets:ApplicationPreferencesBlock />
        </StackPanel>
    </ScrollViewer>
</UserControl>
