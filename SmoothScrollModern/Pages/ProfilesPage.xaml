<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="SmoothScrollModern.Pages.ProfilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:profileWidgets="using:SmoothScrollModern.Widgets.Profiles">

    <ScrollViewer
        HorizontalScrollBarVisibility="Disabled"
        HorizontalScrollMode="Disabled"
        VerticalScrollBarVisibility="Auto">
        <StackPanel
            Margin="32,16,32,32"
            HorizontalAlignment="Stretch"
            Spacing="24">
            <profileWidgets:GlobalScrollProfileBlock />
            <profileWidgets:UserScrollProfilesBlock />
        </StackPanel>
    </ScrollViewer>
</UserControl>
