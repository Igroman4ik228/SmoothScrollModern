<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="SmoothScrollModern.Pages.ExceptionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:applicationWidgets="using:SmoothScrollModern.Widgets.Applications">

    <ScrollViewer
        HorizontalScrollBarVisibility="Disabled"
        HorizontalScrollMode="Disabled"
        VerticalScrollBarVisibility="Auto">
        <StackPanel
            Margin="32,16,32,32"
            HorizontalAlignment="Stretch"
            Spacing="24">
            <applicationWidgets:ActiveApplicationRuleBlock />
            <applicationWidgets:ManualApplicationRuleBlock />
            <applicationWidgets:ApplicationRulesListBlock />
        </StackPanel>
    </ScrollViewer>
</UserControl>
