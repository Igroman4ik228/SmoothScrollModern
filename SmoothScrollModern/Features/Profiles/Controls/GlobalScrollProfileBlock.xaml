<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="SmoothScrollModern.Features.Profiles.Controls.GlobalScrollProfileBlock"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:profiles="using:SmoothScrollModern.Features.Profiles.Controls">

    <Border Style="{StaticResource SurfacePanelStyle}">
        <StackPanel Spacing="14">
            <StackPanel Spacing="3">
                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Основной профиль" />
                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Эти параметры используются везде, где не выбран отдельный профиль исключения." />
            </StackPanel>

            <profiles:ProfileSettingRow
                Description="Сколько прокручивать за один шаг колеса."
                FractionDigits="3"
                Label="Сила прокрутки"
                Maximum="6"
                Minimum="0.2"
                SmallChange="0.05"
                StepFrequency="0.05"
                Value="{Binding ScrollMultiplier, Mode=TwoWay}" />

            <profiles:ProfileSettingRow
                Description="Как долго длится один шаг прокрутки."
                Label="Время прокрутки, мс"
                Maximum="900"
                Minimum="30"
                SmallChange="10"
                StepFrequency="10"
                Value="{Binding DurationMs, Mode=TwoWay}" />

            <profiles:ProfileSettingRow
                Description="Насколько мягко движется прокрутка."
                FractionDigits="3"
                Label="Плавность"
                Maximum="1"
                Minimum="0"
                SmallChange="0.025"
                StepFrequency="0.025"
                Value="{Binding Smoothness, Mode=TwoWay}" />

            <profiles:ProfileSettingRow
                Description="Ускоряет прокрутку при быстрых движениях колеса."
                FractionDigits="3"
                Label="Ускорение"
                Maximum="4"
                Minimum="0.2"
                SmallChange="0.05"
                StepFrequency="0.05"
                Value="{Binding Acceleration, Mode=TwoWay}" />

            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="6">
                    <StackPanel Spacing="2">
                        <TextBlock FontWeight="SemiBold" Text="Поведение прокрутки" />
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Кривая движения во время одного шага." />
                    </StackPanel>
                    <ComboBox
                        DisplayMemberPath="Name"
                        HorizontalAlignment="Stretch"
                        ItemsSource="{Binding EasingOptions}"
                        PlaceholderText="Мягкая"
                        SelectedValue="{Binding EasingType, Mode=TwoWay}"
                        SelectedValuePath="Value" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="6">
                    <StackPanel Spacing="2">
                        <TextBlock FontWeight="SemiBold" Text="Горизонтальная прокрутка" />
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Разрешает горизонтальную прокрутку там, где приложение ее поддерживает." />
                    </StackPanel>
                    <ToggleSwitch
                        IsOn="{Binding EnableHorizontalScroll, Mode=TwoWay}"
                        OffContent="Откл."
                        OnContent="Вкл." />
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
