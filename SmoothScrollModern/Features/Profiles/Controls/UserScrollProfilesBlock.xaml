<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="SmoothScrollModern.Features.Profiles.Controls.UserScrollProfilesBlock"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SmoothScrollModern.Controls"
    xmlns:profiles="using:SmoothScrollModern.Features.Profiles.Controls">

    <StackPanel Spacing="16">
        <Border Style="{StaticResource SurfacePanelStyle}">
            <StackPanel Spacing="14">
                <StackPanel Spacing="3">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Создать профиль" />
                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Новый профиль копирует текущие основные параметры. Потом его можно назначить исключению." />
                </StackPanel>

                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="NewScrollProfileNameBox"
                        VerticalContentAlignment="Center"
                        Header="Название профиля"
                        KeyDown="OnNewScrollProfileNameKeyDown"
                        PlaceholderText="Например: Браузер"
                        Text="{Binding NewScrollProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button
                        Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Command="{Binding AddScrollProfileCommand}"
                        Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE710;" Style="{StaticResource InlineButtonIconStyle}" />
                            <TextBlock Text="Создать" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource SurfacePanelStyle}">
            <StackPanel Spacing="14">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="3">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Пользовательские профили" />
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Найдите профиль, раскройте строку и настройте параметры прокрутки." />
                    </StackPanel>
                    <Border
                        Grid.Column="1"
                        MinWidth="76"
                        Padding="10,5"
                        VerticalAlignment="Top"
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <TextBlock
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding ScrollProfilesCountText}" />
                    </Border>
                </Grid>

                <AutoSuggestBox
                    x:Name="ScrollProfileSearchBox"
                    PlaceholderText="Поиск по названию профиля"
                    QueryIcon="Find"
                    Text="{Binding ScrollProfileSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <controls:ListEmptyState
                    Description="Создайте первый профиль, чтобы назначать приложениям отдельные параметры прокрутки."
                    Title="Список профилей пуст"
                    Visibility="{Binding IsUserScrollProfilesEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <controls:ListEmptyState
                    Description="Проверьте название профиля или очистите строку поиска, чтобы вернуться к полному списку."
                    Title="Профили не найдены"
                    Visibility="{Binding IsScrollProfileSearchEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <ListView
                    MaxHeight="620"
                    HorizontalContentAlignment="Stretch"
                    ItemContainerStyle="{StaticResource BorderlessListViewItemStyle}"
                    ItemsSource="{Binding FilteredUserScrollProfiles}"
                    SelectionMode="None"
                    Style="{StaticResource BorderlessListViewStyle}"
                    Visibility="{Binding HasVisibleUserScrollProfiles, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <profiles:UserScrollProfileItem />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Grid Visibility="{Binding HasScrollProfilesPagination, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{StaticResource CaptionTextStyle}"
                        Text="{Binding ScrollProfilesPageText}" />
                    <PipsPager
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        MaxVisiblePips="7"
                        NextButtonVisibility="Visible"
                        NumberOfPages="{Binding ScrollProfilesPageCount}"
                        PreviousButtonVisibility="Visible"
                        SelectedPageIndex="{Binding ScrollProfilesPageIndex, Mode=TwoWay}" />
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
