<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="SmoothScrollModern.Features.Applications.Controls.AutomaticApplicationRulesBlock"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls">

    <toolkit:SettingsCard
        Description="SmoothScroll не будет вмешиваться в игры, видео и другие полноэкранные окна."
        Header="Полноэкранный режим">
        <ToggleSwitch
            IsOn="{Binding AutoDetectExcludedApps, Mode=TwoWay}"
            OffContent="Откл."
            OnContent="Вкл." />
    </toolkit:SettingsCard>
</UserControl>
