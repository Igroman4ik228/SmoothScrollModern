<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="SmoothScrollModern.Features.Applications.Controls.ApplicationRulesListBlock"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SmoothScrollModern.Controls">

    <Border Style="{StaticResource SurfacePanelStyle}">
        <StackPanel Spacing="14">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="3">
                    <TextBlock
                        Style="{StaticResource SectionTitleStyle}"
                        Text="Правила исключений" />
                    <TextBlock
                        Style="{StaticResource CaptionTextStyle}"
                        Text="Найдите исключение, отключите его или назначьте отдельный профиль прокрутки." />
                </StackPanel>
                <Border
                    Grid.Column="1"
                    MinWidth="76"
                    Padding="10,5"
                    VerticalAlignment="Top"
                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <TextBlock
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding ProfileCountText}" />
                </Border>
            </Grid>

            <AutoSuggestBox
                PlaceholderText="Поиск по названию, процессу или пути"
                QueryIcon="Find"
                Text="{Binding ApplicationSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <controls:ListEmptyState
                Description="Добавьте текущее приложение, укажите процесс вручную или выберите exe-файл, чтобы настроить исключение."
                Title="Список правил пуст"
                Visibility="{Binding IsApplicationRulesEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <controls:ListEmptyState
                Description="Проверьте название приложения, имя процесса или путь к файлу и попробуйте другой запрос."
                Title="Правила не найдены"
                Visibility="{Binding IsApplicationRuleSearchEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <ListView
                MaxHeight="620"
                HorizontalContentAlignment="Stretch"
                ItemContainerStyle="{StaticResource BorderlessListViewItemStyle}"
                ItemsSource="{Binding FilteredApplicationRules}"
                SelectionMode="None"
                Style="{StaticResource BorderlessListViewStyle}"
                Visibility="{Binding HasVisibleApplicationRules, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <controls:ApplicationRuleItem />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Grid Visibility="{Binding HasApplicationRulesPagination, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    VerticalAlignment="Center"
                    Style="{StaticResource CaptionTextStyle}"
                    Text="{Binding ApplicationRulesPageText}" />
                <PipsPager
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    MaxVisiblePips="7"
                    NextButtonVisibility="Visible"
                    NumberOfPages="{Binding ApplicationRulesPageCount}"
                    PreviousButtonVisibility="Visible"
                    SelectedPageIndex="{Binding ApplicationRulesPageIndex, Mode=TwoWay}" />
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
