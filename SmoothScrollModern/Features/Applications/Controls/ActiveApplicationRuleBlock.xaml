<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="SmoothScrollModern.Features.Applications.Controls.ActiveApplicationRuleBlock"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SmoothScrollModern.Features.Applications.Controls"
    x:Name="Root">

    <Border Style="{StaticResource SurfacePanelStyle}">
        <StackPanel Spacing="16">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="6">
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                        Text="Активное приложение" />
                    <controls:ApplicationRuleHeader
                        DisplayName="{Binding CurrentApplicationDisplayNameText}"
                        ExecutablePath="{Binding CurrentApplicationExecutablePathText}"
                        ProcessName="{Binding CurrentApplicationProcessNameText}" />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    AutomationProperties.Name="Удалить правило для активного приложения"
                    Command="{Binding RemoveRuleCommand}"
                    CommandParameter="{Binding CurrentApplicationRule}"
                    ToolTipService.ToolTip="Удалить правило"
                    Visibility="{Binding HasCurrentApplicationRule, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <FontIcon Glyph="&#xE74D;" Style="{StaticResource InlineButtonIconStyle}" />
                </Button>
            </Grid>

            <controls:ApplicationRuleSettings DataContext="{Binding CurrentApplicationRule}" Visibility="{Binding DataContext.HasCurrentApplicationRule, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <Button
                HorizontalAlignment="Left"
                AutomationProperties.Name="Добавить активное приложение в исключения"
                Command="{Binding DisableCurrentApplicationCommand}"
                Style="{StaticResource AccentButtonStyle}"
                ToolTipService.ToolTip="Создать правило для текущего активного приложения"
                Visibility="{Binding IsCurrentApplicationRuleMissing, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE710;" Style="{StaticResource InlineButtonIconStyle}" />
                    <TextBlock Text="Добавить исключение" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Border>
</UserControl>
