<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="SmoothScrollModern.Features.Settings.Controls.ApplicationPreferencesBlock"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls">

    <StackPanel Spacing="28">
        <StackPanel Spacing="14">
            <TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="Персонализация" />
            <StackPanel Spacing="4">
                <toolkit:SettingsCard Description="Тема применяется сразу и может следовать настройкам Windows." Header="Тема">
                    <ComboBox
                        Width="220"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding ThemeOptions}"
                        PlaceholderText="Системная"
                        SelectedValue="{Binding Theme, Mode=TwoWay}"
                        SelectedValuePath="Value" />
                </toolkit:SettingsCard>
            </StackPanel>
        </StackPanel>

        <StackPanel Spacing="14">
            <TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="Конфигурация" />
            <StackPanel Spacing="10">
                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Сохраните настройки в файл, восстановите их или верните значения по умолчанию." />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Command="{Binding ExportSettingsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE74E;" Style="{StaticResource InlineButtonIconStyle}" />
                            <TextBlock Text="Экспорт" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ImportSettingsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8E5;" Style="{StaticResource InlineButtonIconStyle}" />
                            <TextBlock Text="Импорт" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ResetDefaultsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72C;" Style="{StaticResource InlineButtonIconStyle}" />
                            <TextBlock Text="Сбросить" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <StackPanel
            MaxWidth="520"
            HorizontalAlignment="Center"
            Spacing="8">
            <Border
                Width="48"
                Height="48"
                HorizontalAlignment="Center"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <FontIcon
                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                    Glyph="&#xE946;"
                    Style="{StaticResource InlineButtonIconStyle}" />
            </Border>
            <TextBlock
                FontSize="18"
                FontWeight="SemiBold"
                Text="SmoothScroll"
                TextAlignment="Center" />
            <TextBlock
                Style="{StaticResource CaptionTextStyle}"
                Text="Современная плавная прокрутка для Windows для любых приложений."
                TextAlignment="Center" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Text="© Igroman4ik228"
                TextAlignment="Center" />
            <HyperlinkButton
                HorizontalAlignment="Center"
                Content="GitHub"
                NavigateUri="https://github.com/Igroman4ik228/SmoothScrollModern" />
        </StackPanel>
    </StackPanel>
</UserControl>
