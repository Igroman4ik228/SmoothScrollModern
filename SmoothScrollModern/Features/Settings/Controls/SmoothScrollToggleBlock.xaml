<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="SmoothScrollModern.Features.Settings.Controls.SmoothScrollToggleBlock"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:forms="using:SmoothScrollModern.Widgets.Forms">

    <StackPanel Spacing="14">
        <TextBlock
            Style="{StaticResource SettingsSectionTitleStyle}"
            Text="Основное" />
        <StackPanel Spacing="4">
            <forms:SettingToggle
                Description="Когда функция выключена, колесо мыши работает как обычно."
                IsOn="{Binding IsEnabled, Mode=TwoWay}"
                Label="Включить плавную прокрутку" />
        </StackPanel>
    </StackPanel>
</UserControl>
