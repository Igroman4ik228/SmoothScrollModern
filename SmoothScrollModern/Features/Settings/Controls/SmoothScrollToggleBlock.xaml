<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="SmoothScrollModern.Features.Settings.Controls.SmoothScrollToggleBlock"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls">

    <StackPanel Spacing="14">
        <TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="Основное" />
        <StackPanel Spacing="4">
            <toolkit:SettingsCard
                Description="Когда функция выключена, колесо мыши работает как обычно."
                Header="Включить плавную прокрутку"
                HorizontalContentAlignment="Stretch">
                <ToggleSwitch
                    MinWidth="96"
                    VerticalAlignment="Center"
                    IsOn="{Binding IsEnabled, Mode=TwoWay}"
                    OffContent="Откл."
                    OnContent="Вкл." />
            </toolkit:SettingsCard>
            <toolkit:SettingsCard
                Description="SmoothScroll не будет вмешиваться в игры, видео и другие полноэкранные окна."
                Header="Полноэкранный режим"
                HorizontalContentAlignment="Stretch">
                <ToggleSwitch
                    MinWidth="96"
                    VerticalAlignment="Center"
                    IsOn="{Binding AutoDetectExcludedApps, Mode=TwoWay}"
                    OffContent="Откл."
                    OnContent="Вкл." />
            </toolkit:SettingsCard>
        </StackPanel>
    </StackPanel>
</UserControl>
