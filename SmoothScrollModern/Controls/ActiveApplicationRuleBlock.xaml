<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="SmoothScrollModern.Controls.ActiveApplicationRuleBlock"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SmoothScrollModern.Controls">

    <Border Style="{StaticResource SurfacePanelStyle}">
        <StackPanel Spacing="16">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="6">
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                        Text="Активное приложение" />
                    <controls:ApplicationRuleHeader
                        DisplayName="{Binding CurrentApplicationDisplayNameText}"
                        ExecutablePath="{Binding CurrentApplicationExecutablePathText}"
                        ProcessName="{Binding CurrentApplicationProcessNameText}" />
                </StackPanel>
            </Grid>

            <controls:ApplicationRuleSettings
                DataContext="{Binding CurrentApplicationRule}"
                Visibility="{Binding DataContext.HasCurrentApplicationRule, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <Button
                HorizontalAlignment="Left"
                Command="{Binding DisableCurrentApplicationCommand}"
                Style="{StaticResource AccentButtonStyle}"
                Visibility="{Binding IsCurrentApplicationRuleMissing, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon
                        Glyph="&#xE710;"
                        Style="{StaticResource InlineButtonIconStyle}" />
                    <TextBlock Text="Добавить исключение" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Border>
</UserControl>
