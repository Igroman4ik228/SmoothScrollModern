<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="SmoothScrollModern.Controls.ActiveApplicationRuleBlock"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SmoothScrollModern.Controls">

    <Grid
        Padding="0,0,0,18"
        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
        BorderThickness="0,0,0,1"
        RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <controls:ApplicationRuleHeader
            Detail="{Binding CurrentWindowTitle}"
            Label="Текущее окно"
            Subtitle=""
            Title="{Binding CurrentApplicationText}">
            <controls:ApplicationRuleHeader.ActionContent>
                <Button
                    MinWidth="92"
                    Command="{Binding RemoveRuleCommand}"
                    CommandParameter="{Binding CurrentApplicationRule}"
                    Visibility="{Binding HasCurrentApplicationRule, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Delete" />
                        <TextBlock Text="Удалить" />
                    </StackPanel>
                </Button>
            </controls:ApplicationRuleHeader.ActionContent>
        </controls:ApplicationRuleHeader>

        <Grid
            Grid.Row="1"
            Visibility="{Binding HasCurrentApplicationRule, Converter={StaticResource BooleanToVisibilityConverter}}">
            <controls:ApplicationRuleSettings DataContext="{Binding CurrentApplicationRule}" />
        </Grid>

        <Button
            Grid.Row="2"
            HorizontalAlignment="Left"
            MinWidth="190"
            Command="{Binding DisableCurrentApplicationCommand}"
            Style="{StaticResource AccentButtonStyle}"
            Visibility="{Binding IsCurrentApplicationRuleMissing, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <SymbolIcon Symbol="Add" />
                <TextBlock Text="Исключить текущее приложение" />
            </StackPanel>
        </Button>
    </Grid>
</UserControl>
