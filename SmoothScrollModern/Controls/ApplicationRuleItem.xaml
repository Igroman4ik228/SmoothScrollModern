<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="SmoothScrollModern.Controls.ApplicationRuleItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SmoothScrollModern.Controls">

    <Grid
        Padding="0,16,0,18"
        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
        BorderThickness="0,1,0,0"
        RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <controls:ApplicationRuleHeader
            Detail="{Binding ExecutablePathText}"
            Subtitle="{Binding ProcessNameText}"
            Title="{Binding DisplayNameText}">
            <controls:ApplicationRuleHeader.ActionContent>
                <Button
                    MinWidth="92"
                    Click="OnRemoveRuleClick">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Delete" />
                        <TextBlock Text="Удалить" />
                    </StackPanel>
                </Button>
            </controls:ApplicationRuleHeader.ActionContent>
        </controls:ApplicationRuleHeader>

        <controls:ApplicationRuleSettings Grid.Row="1" />
    </Grid>
</UserControl>
