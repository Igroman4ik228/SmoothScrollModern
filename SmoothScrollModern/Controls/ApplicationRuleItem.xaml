<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="SmoothScrollModern.Controls.ApplicationRuleItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SmoothScrollModern.Controls">

    <Border
        Margin="0,0,0,8"
        Style="{StaticResource ListSurfacePanelStyle}">
        <StackPanel Spacing="16">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="2">
                    <TextBlock
                        FontWeight="SemiBold"
                        Text="{Binding DisplayNameText}" />
                    <TextBlock
                        Style="{StaticResource CaptionTextStyle}"
                        Text="{Binding ProcessNameText}" />
                    <TextBlock
                        Style="{StaticResource CaptionTextStyle}"
                        Text="{Binding ExecutablePathText}" />
                </StackPanel>
                <Button
                    Grid.Column="1"
                    Click="OnRemoveRuleClick">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Delete" />
                        <TextBlock Text="Удалить" />
                    </StackPanel>
                </Button>
            </Grid>

            <controls:ApplicationRuleSettings />
        </StackPanel>
    </Border>
</UserControl>
