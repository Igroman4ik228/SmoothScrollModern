<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="SmoothScrollModern.Widgets.Common.ListEmptyState"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid
        MinHeight="180"
        Padding="24,30"
        HorizontalAlignment="Stretch">
        <StackPanel
            MaxWidth="360"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="10">
            <Border
                Width="54"
                Height="54"
                HorizontalAlignment="Center"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="27">
                <FontIcon
                    FontSize="22"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Glyph="{Binding IconGlyph, ElementName=Root}"
                    Style="{StaticResource InlineButtonIconStyle}" />
            </Border>

            <TextBlock
                HorizontalAlignment="Center"
                FontSize="16"
                FontWeight="SemiBold"
                Text="{Binding Title, ElementName=Root}"
                TextAlignment="Center"
                TextWrapping="Wrap" />

            <TextBlock
                HorizontalAlignment="Center"
                Style="{StaticResource CaptionTextStyle}"
                Text="{Binding Description, ElementName=Root}"
                TextAlignment="Center"
                TextWrapping="WrapWholeWords" />
        </StackPanel>
    </Grid>
</UserControl>
