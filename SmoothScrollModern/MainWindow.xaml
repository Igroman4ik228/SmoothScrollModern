<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="SmoothScrollModern.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SmoothScrollModern.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:numberFormatting="using:Windows.Globalization.NumberFormatting"
    Title="SmoothScroll"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="ContentRoot"
        Padding="28,24,28,26"
        Background="Transparent">
        <Grid.Resources>
            <numberFormatting:DecimalFormatter x:Key="DecimalValueFormatter" FractionDigits="3" />

            <Style x:Key="ProfileValueNameStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="ProfileValueDescriptionStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="ProfileSliderStyle" TargetType="Slider">
                <Setter Property="Margin" Value="0,-5,0,-3" />
                <Setter Property="SnapsTo" Value="StepValues" />
            </Style>

            <Style x:Key="TabContentPanelStyle" TargetType="StackPanel">
                <Setter Property="Margin" Value="4,18,18,0" />
                <Setter Property="Spacing" Value="24" />
            </Style>

            <DataTemplate x:Key="ApplicationRuleTemplate">
                <controls:ApplicationRuleItem />
            </DataTemplate>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,22" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock
                    FontSize="26"
                    FontWeight="SemiBold"
                    Text="SmoothScroll" />
                <TextBlock
                    Margin="0,5,0,0"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding StatusText}" />
            </StackPanel>

            <ToggleSwitch
                Grid.Column="1"
                VerticalAlignment="Center"
                IsOn="{Binding IsEnabled, Mode=TwoWay}"
                OffContent="Выключено"
                OnContent="Включено" />
        </Grid>

        <TabView
            Grid.Row="1"
            Background="Transparent"
            CanDragTabs="False"
            IsAddTabButtonVisible="False">
            <TabViewItem Header="Профили" IsClosable="False">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Style="{StaticResource TabContentPanelStyle}">
                        <Border
                            Padding="0,0,0,22"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1"
                            Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="16">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Глобальный профиль" />

                                <Grid ColumnSpacing="14" RowSpacing="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="108" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock Style="{StaticResource ProfileValueNameStyle}" Text="Сила прокрутки" />
                                        <TextBlock Style="{StaticResource ProfileValueDescriptionStyle}" Text="Множитель расстояния за шаг колеса. Больше - дальше и быстрее." />
                                    </StackPanel>
                                    <NumberBox
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Maximum="6"
                                        Minimum="0.2"
                                        NumberFormatter="{StaticResource DecimalValueFormatter}"
                                        SmallChange="0.05"
                                        Style="{StaticResource CompactNumberBoxStyle}"
                                        Value="{Binding ScrollMultiplier, Mode=TwoWay}" />
                                    <Slider
                                        Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Maximum="6"
                                        Minimum="0.2"
                                        StepFrequency="0.05"
                                        Style="{StaticResource ProfileSliderStyle}"
                                        Value="{Binding ScrollMultiplier, Mode=TwoWay}" />
                                </Grid>

                                <Grid ColumnSpacing="14" RowSpacing="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="108" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock Style="{StaticResource ProfileValueNameStyle}" Text="Длительность, мс" />
                                        <TextBlock Style="{StaticResource ProfileValueDescriptionStyle}" Text="Время анимации одного шага. Больше - медленнее и мягче." />
                                    </StackPanel>
                                    <NumberBox
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Maximum="900"
                                        Minimum="30"
                                        SmallChange="10"
                                        Style="{StaticResource CompactNumberBoxStyle}"
                                        Value="{Binding DurationMs, Mode=TwoWay}" />
                                    <Slider
                                        Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Maximum="900"
                                        Minimum="30"
                                        StepFrequency="10"
                                        Style="{StaticResource ProfileSliderStyle}"
                                        Value="{Binding DurationMs, Mode=TwoWay}" />
                                </Grid>

                                <Grid ColumnSpacing="14" RowSpacing="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="108" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock Style="{StaticResource ProfileValueNameStyle}" Text="Плавность" />
                                        <TextBlock Style="{StaticResource ProfileValueDescriptionStyle}" Text="Сглаживает движение между кадрами. Больше - ровнее, меньше - резче." />
                                    </StackPanel>
                                    <NumberBox
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Maximum="1"
                                        Minimum="0"
                                        NumberFormatter="{StaticResource DecimalValueFormatter}"
                                        SmallChange="0.025"
                                        Style="{StaticResource CompactNumberBoxStyle}"
                                        Value="{Binding Smoothness, Mode=TwoWay}" />
                                    <Slider
                                        Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Maximum="1"
                                        Minimum="0"
                                        StepFrequency="0.025"
                                        Style="{StaticResource ProfileSliderStyle}"
                                        Value="{Binding Smoothness, Mode=TwoWay}" />
                                </Grid>

                                <Grid ColumnSpacing="14" RowSpacing="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="108" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock Style="{StaticResource ProfileValueNameStyle}" Text="Ускорение" />
                                        <TextBlock Style="{StaticResource ProfileValueDescriptionStyle}" Text="Усиливает быстрые серии прокрутки. Больше - заметнее разгон." />
                                    </StackPanel>
                                    <NumberBox
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Maximum="4"
                                        Minimum="0.2"
                                        NumberFormatter="{StaticResource DecimalValueFormatter}"
                                        SmallChange="0.05"
                                        Style="{StaticResource CompactNumberBoxStyle}"
                                        Value="{Binding Acceleration, Mode=TwoWay}" />
                                    <Slider
                                        Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Maximum="4"
                                        Minimum="0.2"
                                        StepFrequency="0.05"
                                        Style="{StaticResource ProfileSliderStyle}"
                                        Value="{Binding Acceleration, Mode=TwoWay}" />
                                </Grid>

                                <Grid ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="5">
                                        <TextBlock Style="{StaticResource ProfileValueNameStyle}" Text="Кривая анимации" />
                                        <TextBlock Style="{StaticResource ProfileValueDescriptionStyle}" Text="Распределяет скорость внутри шага: ровно или с мягким замедлением к концу." />
                                        <ComboBox
                                            HorizontalAlignment="Stretch"
                                            ItemsSource="{Binding EasingOptions}"
                                            PlaceholderText="Мягкая"
                                            SelectedValue="{Binding EasingType, Mode=TwoWay}"
                                            Style="{StaticResource SelectionComboBoxStyle}" />
                                    </StackPanel>

                                    <StackPanel
                                        Grid.Column="1"
                                        VerticalAlignment="Bottom"
                                        Spacing="5">
                                        <TextBlock Style="{StaticResource ProfileValueNameStyle}" Text="Горизонтальная прокрутка" />
                                        <TextBlock Style="{StaticResource ProfileValueDescriptionStyle}" Text="Применяет профиль к боковой прокрутке, если приложение ее поддерживает." />
                                        <ToggleSwitch
                                            IsOn="{Binding EnableHorizontalScroll, Mode=TwoWay}"
                                            OffContent="Горизонталь выкл."
                                            OnContent="Горизонталь вкл." />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="16">
                                <Grid ColumnSpacing="18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="5">
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Пользовательские профили" />
                                    </StackPanel>
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding ScrollProfilesCountText}" />
                                </Grid>

                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        VerticalContentAlignment="Center"
                                        PlaceholderText="Новый профиль"
                                        Text="{Binding NewScrollProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button
                                        Grid.Column="1"
                                        Command="{Binding AddScrollProfileCommand}"
                                        Style="{StaticResource AccentButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <SymbolIcon Symbol="Add" />
                                            <TextBlock Text="Создать" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <ListView
                                    ItemContainerStyle="{StaticResource BorderlessListViewItemStyle}"
                                    ItemsSource="{Binding UserScrollProfiles}"
                                    SelectionMode="None"
                                    Style="{StaticResource BorderlessListViewStyle}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel
                                                Padding="0,16,0,18"
                                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                BorderThickness="0,1,0,0"
                                                Spacing="12">
                                                <Grid ColumnSpacing="14">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox
                                                        VerticalContentAlignment="Center"
                                                        PlaceholderText="Название профиля"
                                                        Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    <Button
                                                        Grid.Column="1"
                                                        MinWidth="92"
                                                        VerticalAlignment="Center"
                                                        Click="OnRemoveScrollProfileClick">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <SymbolIcon Symbol="Delete" />
                                                            <TextBlock Text="Удалить" />
                                                        </StackPanel>
                                                    </Button>
                                                </Grid>

                                                <Grid ColumnSpacing="14" RowSpacing="4">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="108" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Style="{StaticResource ProfileValueNameStyle}" Text="Сила прокрутки" />
                                                        <TextBlock Style="{StaticResource ProfileValueDescriptionStyle}" Text="Множитель расстояния за шаг колеса. Больше - дальше и быстрее." />
                                                    </StackPanel>
                                                    <NumberBox
                                                        Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Maximum="6"
                                                        Minimum="0.2"
                                                        NumberFormatter="{StaticResource DecimalValueFormatter}"
                                                        SmallChange="0.05"
                                                        Style="{StaticResource CompactNumberBoxStyle}"
                                                        Value="{Binding ProfileScrollMultiplier, Mode=TwoWay}" />
                                                    <Slider
                                                        Grid.Row="1"
                                                        Grid.ColumnSpan="2"
                                                        Maximum="6"
                                                        Minimum="0.2"
                                                        StepFrequency="0.05"
                                                        Style="{StaticResource ProfileSliderStyle}"
                                                        Value="{Binding ProfileScrollMultiplier, Mode=TwoWay}" />
                                                </Grid>

                                                <Grid ColumnSpacing="14" RowSpacing="4">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="108" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Style="{StaticResource ProfileValueNameStyle}" Text="Длительность, мс" />
                                                        <TextBlock Style="{StaticResource ProfileValueDescriptionStyle}" Text="Время анимации одного шага. Больше - медленнее и мягче." />
                                                    </StackPanel>
                                                    <NumberBox
                                                        Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Maximum="900"
                                                        Minimum="30"
                                                        SmallChange="10"
                                                        Style="{StaticResource CompactNumberBoxStyle}"
                                                        Value="{Binding ProfileDurationMs, Mode=TwoWay}" />
                                                    <Slider
                                                        Grid.Row="1"
                                                        Grid.ColumnSpan="2"
                                                        Maximum="900"
                                                        Minimum="30"
                                                        StepFrequency="10"
                                                        Style="{StaticResource ProfileSliderStyle}"
                                                        Value="{Binding ProfileDurationMs, Mode=TwoWay}" />
                                                </Grid>

                                                <Grid ColumnSpacing="14" RowSpacing="4">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="108" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Style="{StaticResource ProfileValueNameStyle}" Text="Плавность" />
                                                        <TextBlock Style="{StaticResource ProfileValueDescriptionStyle}" Text="Сглаживает движение между кадрами. Больше - ровнее, меньше - резче." />
                                                    </StackPanel>
                                                    <NumberBox
                                                        Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Maximum="1"
                                                        Minimum="0"
                                                        NumberFormatter="{StaticResource DecimalValueFormatter}"
                                                        SmallChange="0.025"
                                                        Style="{StaticResource CompactNumberBoxStyle}"
                                                        Value="{Binding ProfileSmoothness, Mode=TwoWay}" />
                                                    <Slider
                                                        Grid.Row="1"
                                                        Grid.ColumnSpan="2"
                                                        Maximum="1"
                                                        Minimum="0"
                                                        StepFrequency="0.025"
                                                        Style="{StaticResource ProfileSliderStyle}"
                                                        Value="{Binding ProfileSmoothness, Mode=TwoWay}" />
                                                </Grid>

                                                <Grid ColumnSpacing="14" RowSpacing="4">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="108" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Style="{StaticResource ProfileValueNameStyle}" Text="Ускорение" />
                                                        <TextBlock Style="{StaticResource ProfileValueDescriptionStyle}" Text="Усиливает быстрые серии прокрутки. Больше - заметнее разгон." />
                                                    </StackPanel>
                                                    <NumberBox
                                                        Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Maximum="4"
                                                        Minimum="0.2"
                                                        NumberFormatter="{StaticResource DecimalValueFormatter}"
                                                        SmallChange="0.05"
                                                        Style="{StaticResource CompactNumberBoxStyle}"
                                                        Value="{Binding ProfileAcceleration, Mode=TwoWay}" />
                                                    <Slider
                                                        Grid.Row="1"
                                                        Grid.ColumnSpan="2"
                                                        Maximum="4"
                                                        Minimum="0.2"
                                                        StepFrequency="0.05"
                                                        Style="{StaticResource ProfileSliderStyle}"
                                                        Value="{Binding ProfileAcceleration, Mode=TwoWay}" />
                                                </Grid>

                                                <Grid ColumnSpacing="14">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Spacing="5">
                                                        <TextBlock Style="{StaticResource ProfileValueNameStyle}" Text="Кривая анимации" />
                                                        <TextBlock Style="{StaticResource ProfileValueDescriptionStyle}" Text="Распределяет скорость внутри шага: ровно или с мягким замедлением к концу." />
                                                        <ComboBox
                                                            HorizontalAlignment="Stretch"
                                                            Loaded="OnEasingComboBoxLoaded"
                                                            PlaceholderText="Мягкая"
                                                            SelectedValue="{Binding ProfileEasingType, Mode=TwoWay}"
                                                            Style="{StaticResource SelectionComboBoxStyle}" />
                                                    </StackPanel>

                                                    <StackPanel
                                                        Grid.Column="1"
                                                        VerticalAlignment="Bottom"
                                                        Spacing="5">
                                                        <TextBlock Style="{StaticResource ProfileValueNameStyle}" Text="Горизонтальная прокрутка" />
                                                        <TextBlock Style="{StaticResource ProfileValueDescriptionStyle}" Text="Применяет профиль к боковой прокрутке, если приложение ее поддерживает." />
                                                        <ToggleSwitch
                                                            IsOn="{Binding ProfileEnableHorizontalScroll, Mode=TwoWay}"
                                                            OffContent="Горизонталь выкл."
                                                            OnContent="Горизонталь вкл." />
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="Исключения" IsClosable="False">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Style="{StaticResource TabContentPanelStyle}">
                        <controls:ActiveApplicationRuleBlock />

                        <Border
                            Padding="0,0,0,22"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1"
                            Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="16">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Добавить исключение" />
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        VerticalContentAlignment="Center"
                                        PlaceholderText="Например: chrome.exe"
                                        Text="{Binding ManualProcessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button
                                        Grid.Column="1"
                                        Command="{Binding AddManualRuleCommand}"
                                        Style="{StaticResource AccentButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <SymbolIcon Symbol="Add" />
                                            <TextBlock Text="Добавить" />
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="2" Command="{Binding BrowseApplicationCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <SymbolIcon Symbol="OpenFile" />
                                            <TextBlock Text="Обзор" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border
                            Padding="0,0,0,22"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1"
                            Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Автоматические исключения" />
                                <ToggleSwitch
                                    IsOn="{Binding AutoDetectExcludedApps, Mode=TwoWay}"
                                    OffContent="Не отключать в fullscreen"
                                    OnContent="Отключать в полноэкранных окнах" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="16">
                                <Grid ColumnSpacing="18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="5">
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Список исключений" />
                                    </StackPanel>
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding ProfileCountText}" />
                                </Grid>

                                <AutoSuggestBox
                                    PlaceholderText="Поиск по приложению, процессу или пути"
                                    QueryIcon="Find"
                                    Text="{Binding ApplicationSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <ListView
                                    MaxHeight="520"
                                    ItemContainerStyle="{StaticResource BorderlessListViewItemStyle}"
                                    ItemTemplate="{StaticResource ApplicationRuleTemplate}"
                                    ItemsSource="{Binding FilteredApplicationRules}"
                                    SelectionMode="None"
                                    Style="{StaticResource BorderlessListViewStyle}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="Приложение" IsClosable="False">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Style="{StaticResource TabContentPanelStyle}">
                        <Border
                            Padding="0,0,0,22"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1"
                            Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="14">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Запуск и окно" />
                                <ToggleSwitch
                                    IsOn="{Binding StartWithWindows, Mode=TwoWay}"
                                    OffContent="Автозапуск выключен"
                                    OnContent="Автозапуск включён" />

                                <ToggleSwitch
                                    IsOn="{Binding StartMinimizedToTray, Mode=TwoWay}"
                                    OffContent="Показывать окно при запуске"
                                    OnContent="Запускать в tray" />

                                <ToggleSwitch
                                    IsOn="{Binding CloseToTray, Mode=TwoWay}"
                                    OffContent="Крестик завершает приложение"
                                    OnContent="Крестик сворачивает окно в tray" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="14">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Настройки приложения" />
                                <TextBlock Text="Тема" />
                                <ComboBox
                                    Width="220"
                                    HorizontalAlignment="Left"
                                    ItemsSource="{Binding ThemeOptions}"
                                    PlaceholderText="Системная"
                                    SelectedValue="{Binding Theme, Mode=TwoWay}"
                                    Style="{StaticResource SelectionComboBoxStyle}" />

                                <StackPanel
                                    Margin="0,6,0,0"
                                    Orientation="Horizontal"
                                    Spacing="10">
                                    <Button Command="{Binding ExportSettingsCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <SymbolIcon Symbol="Save" />
                                            <TextBlock Text="Экспорт" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding ImportSettingsCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <SymbolIcon Symbol="OpenFile" />
                                            <TextBlock Text="Импорт" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding ResetDefaultsCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <SymbolIcon Symbol="Refresh" />
                                            <TextBlock Text="Сбросить" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>
        </TabView>
    </Grid>
</Window>
