<?xml version="1.0" encoding="utf-8" ?>
<winuiex:WindowEx
    x:Class="SmoothScrollModern.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shell="using:SmoothScrollModern.Widgets.Shell"
    xmlns:winuiex="using:WinUIEx"
    Title="SmoothScroll"
    Width="1120"
    Height="760"
    MinWidth="820"
    MinHeight="560"
    MaxWidth="1600"
    MaxHeight="1000"
    PersistenceId="MainWindow"
    mc:Ignorable="d">

    <winuiex:WindowEx.SystemBackdrop>
        <MicaBackdrop />
    </winuiex:WindowEx.SystemBackdrop>

    <Grid x:Name="ContentRoot" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            MinHeight="48"
            Padding="4,0,0,0"
            Background="Transparent"
            ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="CaptionButtonInsetColumn" Width="138" />
            </Grid.ColumnDefinitions>

            <Button
                Width="44"
                Height="40"
                VerticalAlignment="Center"
                AutomationProperties.Name="Свернуть или развернуть навигацию"
                Click="OnNavigationPaneToggleClick"
                ToolTipService.ToolTip="Свернуть или развернуть навигацию">
                <FontIcon
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="16"
                    Glyph="&#xE700;" />
            </Button>

            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="10">
                <Image
                    Width="24"
                    Height="24"
                    Source="ms-appx:///Assets/Square44x44Logo.scale-200.png"
                    Stretch="UniformToFill" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Text="SmoothScroll"
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Grid>

        <shell:SettingsNavigation x:Name="ShellNavigation" Grid.Row="1" />
    </Grid>
</winuiex:WindowEx>
