<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="SmoothScrollModern.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="SmoothScroll"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="ContentRoot"
        Padding="22"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,18" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock
                    FontSize="28"
                    FontWeight="SemiBold"
                    Text="SmoothScroll" />
                <TextBlock
                    Margin="0,5,0,0"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding StatusText}" />
            </StackPanel>

            <ToggleSwitch
                Grid.Column="1"
                VerticalAlignment="Center"
                IsOn="{Binding IsEnabled, Mode=TwoWay}"
                OffContent="Выключено"
                OnContent="Включено" />
        </Grid>

        <TabView
            Grid.Row="1"
            CanDragTabs="False"
            IsAddTabButtonVisible="False">
            <TabViewItem Header="Профили" IsClosable="False">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,16,0,0" Spacing="14">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Глобальный профиль" />

                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" Text="Сила прокрутки" />
                                    <NumberBox
                                        Grid.Column="1"
                                        Maximum="6"
                                        Minimum="0.2"
                                        SmallChange="0.1"
                                        Style="{StaticResource CompactNumberBoxStyle}"
                                        Value="{Binding ScrollMultiplier, Mode=TwoWay}" />
                                </Grid>
                                <Slider
                                    Maximum="6"
                                    Minimum="0.2"
                                    Value="{Binding ScrollMultiplier, Mode=TwoWay}" />

                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" Text="Длительность анимации, мс" />
                                    <NumberBox
                                        Grid.Column="1"
                                        Maximum="900"
                                        Minimum="30"
                                        SmallChange="10"
                                        Style="{StaticResource CompactNumberBoxStyle}"
                                        Value="{Binding DurationMs, Mode=TwoWay}" />
                                </Grid>
                                <Slider
                                    Maximum="900"
                                    Minimum="30"
                                    StepFrequency="10"
                                    Value="{Binding DurationMs, Mode=TwoWay}" />

                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" Text="Плавность" />
                                    <NumberBox
                                        Grid.Column="1"
                                        Maximum="1"
                                        Minimum="0"
                                        SmallChange="0.05"
                                        Style="{StaticResource CompactNumberBoxStyle}"
                                        Value="{Binding Smoothness, Mode=TwoWay}" />
                                </Grid>
                                <Slider
                                    Maximum="1"
                                    Minimum="0"
                                    StepFrequency="0.01"
                                    Value="{Binding Smoothness, Mode=TwoWay}" />

                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" Text="Ускорение" />
                                    <NumberBox
                                        Grid.Column="1"
                                        Maximum="4"
                                        Minimum="0.2"
                                        SmallChange="0.1"
                                        Style="{StaticResource CompactNumberBoxStyle}"
                                        Value="{Binding Acceleration, Mode=TwoWay}" />
                                </Grid>
                                <Slider
                                    Maximum="4"
                                    Minimum="0.2"
                                    Value="{Binding Acceleration, Mode=TwoWay}" />

                                <TextBlock Text="Кривая анимации" />
                                <ComboBox
                                    Width="220"
                                    HorizontalAlignment="Left"
                                    ItemsSource="{Binding EasingOptions}"
                                    PlaceholderText="Мягкая"
                                    SelectedValue="{Binding EasingType, Mode=TwoWay}"
                                    Style="{StaticResource SelectionComboBoxStyle}" />

                                <ToggleSwitch
                                    IsOn="{Binding EnableHorizontalScroll, Mode=TwoWay}"
                                    OffContent="Горизонтальная прокрутка выключена"
                                    OnContent="Горизонтальная прокрутка включена" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="14">
                                <Grid ColumnSpacing="18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="5">
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Пользовательские профили" />
                                    </StackPanel>
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding ScrollProfilesCountText}" />
                                </Grid>

                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        VerticalContentAlignment="Center"
                                        PlaceholderText="Новый профиль"
                                        Text="{Binding NewScrollProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button
                                        Grid.Column="1"
                                        Command="{Binding AddScrollProfileCommand}"
                                        Content="Создать профиль" />
                                </Grid>

                                <ListView
                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    ItemsSource="{Binding UserScrollProfiles}"
                                    SelectionMode="None">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Padding" Value="0" />
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Padding="14,12,14,16" Spacing="12">
                                                <Grid ColumnSpacing="14">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox
                                                        VerticalContentAlignment="Center"
                                                        PlaceholderText="Название профиля"
                                                        Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    <Button
                                                        Grid.Column="1"
                                                        MinWidth="92"
                                                        VerticalAlignment="Center"
                                                        Click="OnRemoveScrollProfileClick"
                                                        Content="Удалить" />
                                                </Grid>

                                                <Grid ColumnSpacing="16">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="120" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock VerticalAlignment="Center" Text="Сила прокрутки" />
                                                    <NumberBox
                                                        Grid.Column="1"
                                                        Maximum="6"
                                                        Minimum="0.2"
                                                        SmallChange="0.1"
                                                        Style="{StaticResource CompactNumberBoxStyle}"
                                                        Value="{Binding ProfileScrollMultiplier, Mode=TwoWay}" />
                                                </Grid>
                                                <Slider
                                                    Maximum="6"
                                                    Minimum="0.2"
                                                    Value="{Binding ProfileScrollMultiplier, Mode=TwoWay}" />

                                                <Grid ColumnSpacing="16">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="120" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock VerticalAlignment="Center" Text="Длительность анимации, мс" />
                                                    <NumberBox
                                                        Grid.Column="1"
                                                        Maximum="900"
                                                        Minimum="30"
                                                        SmallChange="10"
                                                        Style="{StaticResource CompactNumberBoxStyle}"
                                                        Value="{Binding ProfileDurationMs, Mode=TwoWay}" />
                                                </Grid>
                                                <Slider
                                                    Maximum="900"
                                                    Minimum="30"
                                                    StepFrequency="10"
                                                    Value="{Binding ProfileDurationMs, Mode=TwoWay}" />

                                                <Grid ColumnSpacing="16">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="120" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock VerticalAlignment="Center" Text="Плавность" />
                                                    <NumberBox
                                                        Grid.Column="1"
                                                        Maximum="1"
                                                        Minimum="0"
                                                        SmallChange="0.05"
                                                        Style="{StaticResource CompactNumberBoxStyle}"
                                                        Value="{Binding ProfileSmoothness, Mode=TwoWay}" />
                                                </Grid>
                                                <Slider
                                                    Maximum="1"
                                                    Minimum="0"
                                                    StepFrequency="0.01"
                                                    Value="{Binding ProfileSmoothness, Mode=TwoWay}" />

                                                <Grid ColumnSpacing="16">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="120" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock VerticalAlignment="Center" Text="Ускорение" />
                                                    <NumberBox
                                                        Grid.Column="1"
                                                        Maximum="4"
                                                        Minimum="0.2"
                                                        SmallChange="0.1"
                                                        Style="{StaticResource CompactNumberBoxStyle}"
                                                        Value="{Binding ProfileAcceleration, Mode=TwoWay}" />
                                                </Grid>
                                                <Slider
                                                    Maximum="4"
                                                    Minimum="0.2"
                                                    Value="{Binding ProfileAcceleration, Mode=TwoWay}" />

                                                <TextBlock Text="Кривая анимации" />
                                                <ComboBox
                                                    Width="220"
                                                    HorizontalAlignment="Left"
                                                    Loaded="OnEasingComboBoxLoaded"
                                                    PlaceholderText="Мягкая"
                                                    SelectedValue="{Binding ProfileEasingType, Mode=TwoWay}"
                                                    Style="{StaticResource SelectionComboBoxStyle}" />

                                                <ToggleSwitch
                                                    IsOn="{Binding ProfileEnableHorizontalScroll, Mode=TwoWay}"
                                                    OffContent="Горизонтальная прокрутка выключена"
                                                    OnContent="Горизонтальная прокрутка включена" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="Исключения" IsClosable="False">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,16,0,0" Spacing="14">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="6">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Активное приложение" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{Binding CurrentApplicationText}"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Text="{Binding CurrentWindowTitle}"
                                    TextTrimming="CharacterEllipsis" />
                                <CheckBox
                                    MinWidth="190"
                                    Margin="0,4,0,0"
                                    Content="Исключение активно"
                                    IsChecked="{Binding IsCurrentApplicationBypassed, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="Полноэкранные окна" />
                                <ToggleSwitch
                                    IsOn="{Binding AutoDetectExcludedApps, Mode=TwoWay}"
                                    OffContent="Не отключать fullscreen автоматически"
                                    OnContent="Отключать плавную прокрутку в fullscreen" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="14">
                                <StackPanel Spacing="5">
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Добавить приложение" />
                                </StackPanel>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        VerticalContentAlignment="Center"
                                        PlaceholderText="Например: chrome.exe"
                                        Text="{Binding ManualProcessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button
                                        Grid.Column="1"
                                        Command="{Binding AddManualRuleCommand}"
                                        Content="Добавить" />
                                    <Button
                                        Grid.Column="2"
                                        Command="{Binding BrowseApplicationCommand}"
                                        Content="Выбрать .exe" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="14">
                                <Grid ColumnSpacing="18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="5">
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Правила приложений" />
                                    </StackPanel>
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding ProfileCountText}" />
                                </Grid>

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="Поиск" />
                                    <TextBox
                                        Grid.Column="1"
                                        VerticalContentAlignment="Center"
                                        PlaceholderText="Название, процесс или путь"
                                        Text="{Binding ApplicationSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <ListView
                                    MaxHeight="520"
                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    ItemsSource="{Binding FilteredApplicationRules}"
                                    SelectionMode="None">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Padding" Value="0" />
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="14" RowSpacing="14">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Grid ColumnSpacing="14">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" MinWidth="260" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel VerticalAlignment="Center" Spacing="4">
                                                        <TextBlock
                                                            FontSize="16"
                                                            FontWeight="SemiBold"
                                                            Text="{Binding DisplayNameText}"
                                                            TextTrimming="CharacterEllipsis" />
                                                        <TextBlock
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            Text="{Binding ProcessNameText}"
                                                            TextTrimming="CharacterEllipsis" />
                                                        <TextBlock
                                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                            Text="{Binding ExecutablePathText}"
                                                            TextTrimming="CharacterEllipsis"
                                                            Visibility="{Binding HasExecutablePath, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                        <TextBlock
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            Text="{Binding ActiveStateText}"
                                                            TextWrapping="Wrap" />
                                                    </StackPanel>

                                                    <Button
                                                        Grid.Column="1"
                                                        MinWidth="92"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        Click="OnRemoveRuleClick"
                                                        Content="Удалить" />
                                                </Grid>

                                                <Grid
                                                    Grid.Row="1"
                                                    ColumnSpacing="18"
                                                    RowSpacing="12">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <ToggleSwitch
                                                        IsOn="{Binding IsRuleEnabled, Mode=TwoWay}"
                                                        OffContent="Правило выключено"
                                                        OnContent="Правило активно" />

                                                    <ToggleSwitch
                                                        Grid.Column="1"
                                                        IsOn="{Binding IsSmoothScrollDisabled, Mode=TwoWay}"
                                                        OffContent="Использовать профиль"
                                                        OnContent="Отключить прокрутку" />

                                                    <StackPanel Grid.Row="1" Spacing="5">
                                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Режим" />
                                                        <ComboBox
                                                            HorizontalAlignment="Stretch"
                                                            Loaded="OnDeliveryModeComboBoxLoaded"
                                                            PlaceholderText="Плавный режим"
                                                            SelectedValue="{Binding DeliveryMode, Mode=TwoWay}"
                                                            Style="{StaticResource SelectionComboBoxStyle}" />
                                                    </StackPanel>

                                                    <StackPanel
                                                        Grid.Row="1"
                                                        Grid.Column="1"
                                                        Spacing="5">
                                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Профиль прокрутки" />
                                                        <ComboBox
                                                            HorizontalAlignment="Stretch"
                                                            DisplayMemberPath="Name"
                                                            Loaded="OnRuleProfileComboBoxLoaded"
                                                            PlaceholderText="Глобальный профиль"
                                                            SelectedValue="{Binding ScrollProfileId, Mode=TwoWay}"
                                                            SelectedValuePath="Id" />
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="Приложение" IsClosable="False">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,16,0,0" Spacing="14">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Запуск и окно" />
                                <ToggleSwitch
                                    IsOn="{Binding StartWithWindows, Mode=TwoWay}"
                                    OffContent="Автозапуск выключен"
                                    OnContent="Автозапуск включён" />

                                <ToggleSwitch
                                    IsOn="{Binding StartMinimizedToTray, Mode=TwoWay}"
                                    OffContent="Показывать окно при запуске"
                                    OnContent="Запускать в tray" />

                                <ToggleSwitch
                                    IsOn="{Binding CloseToTray, Mode=TwoWay}"
                                    OffContent="Крестик завершает приложение"
                                    OnContent="Крестик сворачивает окно в tray" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Настройки приложения" />
                                <TextBlock Text="Тема" />
                                <ComboBox
                                    Width="220"
                                    HorizontalAlignment="Left"
                                    ItemsSource="{Binding ThemeOptions}"
                                    PlaceholderText="Системная"
                                    SelectedValue="{Binding Theme, Mode=TwoWay}"
                                    Style="{StaticResource SelectionComboBoxStyle}" />

                                <StackPanel
                                    Margin="0,6,0,0"
                                    Orientation="Horizontal"
                                    Spacing="10">
                                    <Button Command="{Binding ExportSettingsCommand}" Content="Экспорт" />
                                    <Button Command="{Binding ImportSettingsCommand}" Content="Импорт" />
                                    <Button Command="{Binding ResetDefaultsCommand}" Content="Сбросить" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>
        </TabView>
    </Grid>
</Window>
